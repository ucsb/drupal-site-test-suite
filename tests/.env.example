# Environment variables honored by the Drupal 10 / 11 test suite.
#
# Copy this file to `.env` (do NOT commit `.env`) and adjust values for
# your local environment. Tools like direnv or lando will pick up these
# values automatically; otherwise `export` them in your shell before
# running drush commands.
#
# Categories:
#   - Required for accessibility tests
#   - Optional crawl tuning
#   - Accessibility profile selection
#   - Output / reporting
#   - axe Developer Hub integration (optional)
#   - Edge / staging authentication (reserved — not yet active)
#   - CI-only (set automatically by GitHub Actions)


# ---------------------------------------------------------------------
# Required for accessibility tests
# ---------------------------------------------------------------------

# The base URL of your local Drupal site, served by your local dev
# environment (DDEV, Lando, plain Apache/Nginx, drush rs, etc.).
# Examples:
#   BASE_URL=https://my-site.ddev.site
#   BASE_URL=https://my-site.lndo.site
#   BASE_URL=http://127.0.0.1:8888
#
# Windows + WSL2: drush runs inside the WSL distro, and Lando/DDEV
# URLs resolve from both Windows and WSL via host-file or dnsmasq
# routing. Use the same URL you'd visit in your browser. Native
# Windows shells (cmd / PowerShell) without WSL or a Linux container
# aren't supported — drush invokes bash, which isn't available there.
BASE_URL=http://127.0.0.1:8888


# ---------------------------------------------------------------------
# Optional crawl tuning
# ---------------------------------------------------------------------

# Sitemap URL used by the a11y commands (utest:alfa, utest:axe,
# utest:axe-watcher, etc.). Defaults to ${BASE_URL}/sitemap.xml if
# unset. Override only if your sitemap lives at a non-standard path.
# SITEMAP_URL=https://my-site.ddev.site/sitemap.xml

# Cap the number of pages each full-site lane will crawl. Useful on very
# large sites where the default crawl is too slow for iterative local
# development. Each lane reads its own variable and defaults to 50 pages
# (the drush `--max-pages=N` / `--max-pages=all` flag overrides these).
# ALFA_MAX_PAGES=50
# AXE_MAX_PAGES=50
# REFLOW_MAX_PAGES=50
# META_VIEWPORT_MAX_PAGES=50


# ---------------------------------------------------------------------
# Optional local custom-code scope filters
# ---------------------------------------------------------------------

# Local-only filters for repeatedly running test lanes against selected
# custom code. CLI flags override these values. Leave unset for the full
# custom-code suite. These filters do not include contrib. Use
# `drush utest:phpunit --ignore-scope` to bypass these for one run.
#
# Supported today: utest:phpunit and utest:lint.
# Planned for later: additional custom-code lanes.
# UTEST_CUSTOM_MODULES=my_custom_module,another_custom_module
# UTEST_CUSTOM_THEMES=my_custom_theme,another_custom_theme
# UTEST_CUSTOM_PROFILES=my_custom_profile,another_custom_profile


# ---------------------------------------------------------------------
# Accessibility profile selection
# ---------------------------------------------------------------------

# Which testing profile to apply. Defined in
# tests/accessibility/config/a11y-profiles.js. Values:
#   strict          — WCAG Level A only
#   standard        — WCAG Level A + AA
#   comprehensive   — All WCAG levels + best practices (default)
#   custom          — User-defined via A11Y_CUSTOM_TAGS
A11Y_PROFILE=comprehensive

# Custom rule tags (only used when A11Y_PROFILE=custom). Comma-separated
# list of axe / Alfa rule tags. Example:
#   A11Y_CUSTOM_TAGS=wcag2a,wcag2aa,best-practice
# A11Y_CUSTOM_TAGS=

# Override severity levels reported. Comma-separated subset of:
#   critical,serious,moderate,minor
# Example:
#   A11Y_SEVERITY_LEVELS=critical,serious
# A11Y_SEVERITY_LEVELS=


# ---------------------------------------------------------------------
# Output / reporting
# ---------------------------------------------------------------------

# Override the directory where each lane's reports are written. Defaults to
# web/sites/default/files/test-reports/<lane>/ (local) or
# tests/reports/<lane>/ (CI). PLAYWRIGHT_REPORT_DIR overrides the base
# Playwright report location used by the a11y lanes.
# ALFA_OUTPUT_DIR=
# AXE_OUTPUT_DIR=
# REFLOW_OUTPUT_DIR=
# META_VIEWPORT_OUTPUT_DIR=
# PLAYWRIGHT_REPORT_DIR=

# Disable Alfa's network-dependent rule features. Useful when running
# locally without external network access. Defaults to true.
# ALFA_DISABLE_NETWORK_FEATURES=true


# ---------------------------------------------------------------------
# axe Developer Hub integration (optional)
# ---------------------------------------------------------------------

# API key for axe Developer Hub. Without this, drush utest:axe-watcher
# skips cleanly (no fallback to a basic lane).
# AXE_API_KEY=


# ---------------------------------------------------------------------
# Edge / staging authentication (reserved — not yet active)
# ---------------------------------------------------------------------

# RESERVED: no current test reads these. They are placeholders for
# planned authenticated-content tests that would apply HTTP basic auth
# at the Playwright context level when crawling staging environments
# behind edge auth (e.g. preview/multidev environments behind edge auth).
# Setting them today has no effect; leave unset.
# HTTP_BASIC_USER=
# HTTP_BASIC_PASS=


# ---------------------------------------------------------------------
# CI-only
# ---------------------------------------------------------------------

# Set automatically by GitHub Actions (natively or by the workflow) to
# label reports with PR/branch/environment context. Do not set manually
# in .env.
#   CI=true
#   GITHUB_ACTIONS=true
#   MULTIDEV_URL=...            # target multidev URL under test
#   PR_NUMBER / GITHUB_PR_NUMBER
#   GIT_BRANCH / GITHUB_HEAD_REF
#   GITHUB_REPOSITORY / GITHUB_RUN_ID / GITHUB_SERVER_URL
